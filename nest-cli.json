{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/linkwatch/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/linkwatch/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/linkwatch",
  "projects": {
    "analytics": {
      "type": "library",
      "root": "libs/analytics",
      "entryFile": "index",
      "sourceRoot": "libs/analytics/src",
      "compilerOptions": {
        "tsConfigPath": "libs/analytics/tsconfig.lib.json"
      }
    },
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "linkwatch": {
      "type": "application",
      "root": "apps/linkwatch",
      "entryFile": "main",
      "sourceRoot": "apps/linkwatch/src",
      "compilerOptions": {
        "tsConfigPath": "apps/linkwatch/tsconfig.app.json"
      }
    },
    "lw-api": {
      "type": "application",
      "root": "apps/lw-api",
      "entryFile": "main",
      "sourceRoot": "apps/lw-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/lw-api/tsconfig.app.json"
      }
    },
    "prisma": {
      "type": "library",
      "root": "libs/prisma",
      "entryFile": "index",
      "sourceRoot": "libs/prisma/src",
      "compilerOptions": {
        "tsConfigPath": "libs/prisma/tsconfig.lib.json"
      }
    }
  }
}